# HTTP port the signaling server listens on
PORT=8787
# Origin allowed to connect to the signaling server (the Vite dev server)
ALLOWED_ORIGIN=http://127.0.0.1:5173
# Audience DID the client mints service-auth tokens for (did:web of the page host).
# Must match what the browser sends: did:web:<window.location.host>
SIGNALING_SERVER_DID=did:web:127.0.0.1:5173
# Port the Vite client dev server listens on
CLIENT_PORT=5173
# DEV ONLY: when '1', the signaling server accepts an auth-handshake whose
# token verification fails and trusts the handshake's claimed DID, so two
# local accounts can be tested while the OAuth getServiceAuth 403 is root-caused.
# Only takes effect when NODE_ENV=development; the server refuses to boot if
# this flag is set while NODE_ENV is anything else (including unset).
# Never set this in production. Leave unset for normal (verified) behavior.
# DEV_ALLOW_UNVERIFIED_AUTH=1
# NSID (Lexicon method name) this server requires on getServiceAuth JWTs it
# accepts. Must match the granular "rpc:<lxm>?aud=..." scope requested in
# client/public/client-metadata.json (OAuth re-consent is required after
# changing this). Defaults to com.bluecall.signaling.connect when unset.
SIGNALING_LXM=com.bluecall.signaling.connect
